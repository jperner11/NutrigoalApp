{
  "expo": {
    "name": "Meal & Motion",
    "slug": "nutrigoal",
    "version": "1.0.0",
    "entryPoint": "./index.js",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutrigoal",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f8fc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutrigoal.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Meal & Motion reads your health data to sync workouts, steps, weight, and water intake.",
        "NSHealthUpdateUsageDescription": "Meal & Motion writes workout and water data to keep your Health app up to date."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f3f8fc",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.nutrigoal.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
