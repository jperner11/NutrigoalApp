# E2E test environment — copy to apps/web/.env.e2e and fill in.
# This MUST point at a throwaway TEST Supabase project, never production.
# The seed layer refuses to run if E2E_SUPABASE_URL matches the prod URL in .env.local.

# The running app the agent/tests hit. Local dev (npm run dev:web) or a Vercel preview URL.
E2E_BASE_URL=http://localhost:3000

# A SEPARATE Supabase project's credentials (Project Settings → API).
E2E_SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=your-test-project-service-role-key

# Public anon key of the TEST project (Project Settings → API → Project API keys).
# Needed so Playwright can start the app pointed at the test project (the browser
# client uses this). Not needed if E2E_BASE_URL is an already-running deploy.
E2E_SUPABASE_ANON_KEY=your-test-project-anon-key

# Optional. Synthetic test emails use this domain; it never needs to receive mail
# because users are created pre-confirmed via the admin API.
E2E_EMAIL_DOMAIN=e2e.treno.test

# Escape hatch — only set to 1 if you REALLY mean to run against the prod DB. Don't.
# E2E_ALLOW_PROD=0
